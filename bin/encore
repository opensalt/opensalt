#!/bin/sh

cd $(dirname $0)/..

mkdir -p -m 0777 build/js
rm -f ./build/js/apx.js

cat ./app/Resources/assets/js/cftree/view-documentclass.js > ./build/js/apx.js
cat ./app/Resources/assets/js/cftree/view-trees.js >> ./build/js/apx.js
cat ./app/Resources/assets/js/cftree/view-edit.js >> ./build/js/apx.js
cat ./app/Resources/assets/js/cftree/view-modes.js >> ./build/js/apx.js
cat ./app/Resources/assets/js/cftree/viewx.js >> ./build/js/apx.js
cat ./app/Resources/assets/js/cftree/apxglobal.js >> ./build/js/apx.js

rm -rf ./web/build/*

docker run --rm -u $(id -u):$(id -g) -v $(pwd):/build/app opensalt/encore "$@"
